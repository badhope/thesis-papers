{
  "name": "nuclearsim-pro",
  "version": "3.0.0",
  "description": "专业级核武器效应模拟器 - NuclearSim Pro",
  "main": "electron/main.js",
  "author": "NuclearSim Team",
  "license": "MIT",
  "homepage": "https://github.com/badhope/bumb",
  "repository": {
    "type": "git",
    "url": "https://github.com/badhope/bumb.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "dist": "electron-builder --publish=never",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.nuclearsim.pro",
    "productName": "NuclearSim Pro",
    "copyright": "Copyright © 2026 NuclearSim Team",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icons/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icons/icon.ico",
      "uninstallerIcon": "assets/icons/icon.ico",
      "installerHeaderIcon": "assets/icons/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NuclearSim Pro"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icons/icon.icns",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icons",
      "category": "Education"
    },
    "publish": {
      "provider": "github",
      "owner": "badhope",
      "repo": "bumb",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "electron-updater": "^6.1.7",
    "echarts": "^5.5.0",
    "leaflet": "^1.9.4",
    "three": "^0.161.0",
    "pdfmake": "^0.2.9",
    "docx": "^8.5.0",
    "sharp": "^0.33.2"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
